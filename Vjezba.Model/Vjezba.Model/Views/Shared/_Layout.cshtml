<!DOCTYPE html>
<html lang="hr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kino Sustav</title>
    <!-- Removed Bootstrap for custom Cinematic UI/UX -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Vjezba.Model.styles.css" asp-append-version="true" />
</head>

<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";

        var uiControllerLabels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Home"] = "Početna",
            ["Cinema"] = "Kina",
            ["Customer"] = "Kupci",
            ["Hall"] = "Dvorane",
            ["Movie"] = "Filmovi",
            ["Screening"] = "Projekcije",
            ["Seat"] = "Sjedala",
            ["Ticket"] = "Ulaznice",
            ["TicketBuilder"] = "Brza Kupnja"
        };

        var uiActionLabels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Index"] = "Pregled",
            ["Details"] = "Detalji"
        };

        var ticketBuilderActionLabels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Index"] = "Odabir kina",
            ["Movies"] = "Odabir filma",
            ["Screenings"] = "Odabir projekcije",
            ["Seats"] = "Odabir sjedala"
        };

        var currentControllerLabel = uiControllerLabels.TryGetValue(currentController, out var controllerLabel)
            ? controllerLabel
            : currentController;

        var currentActionLabel = uiActionLabels.TryGetValue(currentAction, out var actionLabel)
            ? actionLabel
            : currentAction;

        if (string.Equals(currentController, "TicketBuilder", StringComparison.OrdinalIgnoreCase)
            && ticketBuilderActionLabels.TryGetValue(currentAction, out var ticketBuilderActionLabel))
        {
            currentActionLabel = ticketBuilderActionLabel;
        }
    }
    <header class="site-header">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="nav-brand" asp-area="" asp-controller="Home" asp-action="Index">Kino Sustav</a>
            <nav>
                <ul class="nav-menu">
                    <li><a class="nav-link @(currentController == "Home" ? "active" : "")" asp-controller="Home"
                               asp-action="Index">Početna</a></li>
                        <li><a class="nav-link @(currentController == "Movie" ? "active" : "")" asp-controller="Movie"
                                   asp-action="Index">Filmovi</a></li>
                            <li><a class="nav-link @(currentController == "Screening" ? "active" : "")"
                                       asp-controller="Screening" asp-action="Index">Projekcije</a></li>
                                <li><a class="nav-link @(currentController == "Cinema" ? "active" : "")" asp-controller="Cinema"
                                           asp-action="Index">Kina</a></li>
                                    <li><a class="nav-link @(currentController == "Hall" ? "active" : "")" asp-controller="Hall"
                                               asp-action="Index">Dvorane</a></li>
                                        <li><a class="nav-link @(currentController == "Seat" ? "active" : "")" asp-controller="Seat"
                                                   asp-action="Index">Sjedala</a></li>
                                            <li><a class="nav-link @(currentController == "Customer" ? "active" : "")" asp-controller="Customer"
                                                       asp-action="Index">Kupci</a></li>
                                                <li><a class="nav-link @(currentController == "Ticket" ? "active" : "")" asp-controller="Ticket"
                                                           asp-action="Index">Ulaznice</a></li>
                                                    <li><a class="nav-link @(currentController == "TicketBuilder" ? "active" : "")"
                                                               asp-controller="TicketBuilder" asp-action="Index">Brza Kupnja</a></li>
                                                    </ul>
                                                </nav>
                                            </div>
                                        </header>

                                        <div class="container site-main-container">
                                            @if (!(currentController == "Home" && currentAction == "Index"))
                                            {
                                                <nav aria-label="breadcrumb">
                                                    <ol class="breadcrumb">
                                                        <li class="breadcrumb-item">
                                                            <a asp-area="" asp-controller="Home" asp-action="Index">Početna</a>
                                                        </li>
                                                        @if (!string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            if (string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <li class="breadcrumb-item active" aria-current="page">@currentControllerLabel</li>
                                                            }
                                                            else
                                                            {
                                                                <li class="breadcrumb-item">
                                                                    <a asp-area="" asp-controller="@currentController" asp-action="Index">@currentControllerLabel</a>
                                                                </li>
                                                                <li class="breadcrumb-item active" aria-current="page">@currentActionLabel</li>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <li class="breadcrumb-item active" aria-current="page">@currentActionLabel</li>
                                                        }
                                                    </ol>
                                                </nav>
                                            }

                                            <main role="main">
                                                @RenderBody()
                                            </main>
                                        </div>

                                        <footer class="site-footer">
                                            <div class="container">
                                                &copy; 2026 - Sustav za prodaju kino ulaznica
                                            </div>
                                        </footer>
                                        <script src="~/lib/jquery/dist/jquery.min.js"></script>
                                        <script src="~/js/site.js" asp-append-version="true"></script>
                                        @await RenderSectionAsync("Scripts", required: false)
                                    </body>

                                </html>
