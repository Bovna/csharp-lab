@model List<Vjezba.Model.Models.Entities.Customer>

@{
    ViewData["Title"] = "Kupci";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    Popis kupaca</h1>
                    <span class="cinema-badge">Ukupno: @Model.Count</span>
                </div>

                <div class="cinema-card">
                    <div class="cinema-table-wrapper cinema-table-wrapper--no-scroll">
                        <table class="table entity-index-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Ime</th>
                                    <th>Prezime</th>
                                    <th>Grad</th>
                                    <th>Adresa</th>
                                    <th>E-posta</th>
                                    <th>Telefon</th>
                                    <th>Registriran</th>
                                    <th>Loyalty member</th>
                                    <th>Loyalty points</th>
                                    <th>Dodatno</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var customer in Model)
                                {
                                    <tr>
                                        <td class="text-muted">@customer.Id</td>
                                        <td>@customer.FirstName</td>
                                        <td>@customer.LastName</td>
                                        <td>@customer.City</td>
                                        <td>@customer.Street @customer.HouseNumber</td>
                                        <td>@customer.Email</td>
                                        <td>@customer.Phone</td>
                                        <td>@customer.RegisteredAt.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            @if (customer.IsLoyaltyMember)
                                            {
                                                <span class="cinema-status-yes">Da</span>
                                            }
                                            else
                                            {
                                                <span class="cinema-status-no">Ne</span>
                                            }
                                        </td>
                                        <td>@customer.LoyaltyPoints</td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@customer.Id"
                                               class="cinema-btn-outline">Detalji</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
