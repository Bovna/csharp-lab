@model List<Vjezba.Model.Models.Entities.Customer>

@{
    ViewData["Title"] = "Kupci";
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h3 mb-0">Popis kupaca</h1>
                <span class="badge bg-primary">Ukupno: @Model.Count</span>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Ime</th>
                                <th>Prezime</th>
                                <th>Grad</th>
                                <th>Adresa</th>
                                <th>E-posta</th>
                                <th>Telefon</th>
                                <th>Registriran</th>
                                <th>Clan programa vjernosti</th>
                                <th>Bodovi programa vjernosti</th>
                                <th class="text-end">Akcije</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var customer in Model)
                            {
                                <tr>
                                    <td>@customer.Id</td>
                                    <td>@customer.FirstName</td>
                                    <td>@customer.LastName</td>
                                    <td>@customer.City</td>
                                    <td>@customer.Street @customer.HouseNumber</td>
                                    <td>@customer.Email</td>
                                    <td>@customer.Phone</td>
                                    <td>@customer.RegisteredAt.ToString("dd.MM.yyyy")</td>
                                    <td>@(customer.IsLoyaltyMember ? "Da" : "Ne")</td>
                                    <td>@customer.LoyaltyPoints</td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@customer.Id" class="btn btn-sm btn-outline-primary">Detalji</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
