@model Vjezba.Model.Models.Entities.Customer

@{
    ViewData["Title"] = "Detalji kupca";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h3 mb-0">@Model.FirstName @Model.LastName</h1>
                <a asp-action="Index" class="btn btn-outline-secondary">Natrag na popis</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">Ime</dt>
                        <dd class="col-sm-8">@Model.FirstName</dd>

                        <dt class="col-sm-4">Prezime</dt>
                        <dd class="col-sm-8">@Model.LastName</dd>

                        <dt class="col-sm-4">Grad</dt>
                        <dd class="col-sm-8">@Model.City</dd>

                        <dt class="col-sm-4">Adresa</dt>
                        <dd class="col-sm-8">@Model.Street @Model.HouseNumber, @Model.PostalCode</dd>

                        <dt class="col-sm-4">E-posta</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Telefon</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4">Datum registracije</dt>
                        <dd class="col-sm-8">@Model.RegisteredAt.ToString("dd.MM.yyyy")</dd>

                        <dt class="col-sm-4">Clan programa vjernosti</dt>
                        <dd class="col-sm-8">@(Model.IsLoyaltyMember ? "Da" : "Ne")</dd>

                        <dt class="col-sm-4">Bodovi programa vjernosti</dt>
                        <dd class="col-sm-8">@Model.LoyaltyPoints</dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header">Ulaznice kupca</div>
                <div class="card-body p-0">
                    @if (Model.Tickets.Count == 0)
                    {
                        <div class="p-3 text-muted">Kupac nema ulaznica.</div>
                    }
                    else
                    {
                        <table class="table table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Broj ulaznice</th>
                                    <th>Film</th>
                                    <th>Kino</th>
                                    <th>Dvorana</th>
                                    <th>Sjedalo</th>
                                    <th>Kupnja</th>
                                    <th>Cijena (EUR)</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.Tickets)
                                {
                                    <tr>
                                        <td>@ticket.TicketNumber</td>
                                        <td>@(ticket.Screening?.Movie?.Title ?? "-")</td>
                                        <td>@(ticket.Screening?.Hall?.Cinema?.Name ?? "-")</td>
                                        <td>@(ticket.Screening?.Hall?.Name ?? "-")</td>
                                        <td>@(ticket.Seat is null ? "-" : $"{ticket.Seat.RowLabel}{ticket.Seat.SeatNumber}")</td>
                                        <td>@ticket.PurchasedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@ticket.Price.ToString("0.00")</td>
                                        <td>
                                            @(ticket.Status switch
                                            {
                                                Vjezba.Model.Models.Entities.TicketStatus.Active => "Aktivna",
                                                Vjezba.Model.Models.Entities.TicketStatus.Cancelled => "Otkazana",
                                                Vjezba.Model.Models.Entities.TicketStatus.Used => "Iskoristena",
                                                _ => ticket.Status.ToString()
                                            })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
