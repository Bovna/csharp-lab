@model Vjezba.Model.Models.ViewModels.CustomerDetailsViewModel

@{
    ViewData["Title"] = "Detalji kupca";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    @Model.Customer.FirstName @Model.Customer.LastName</h1>
                    <a asp-action="Index" class="cinema-btn-secondary">Natrag na popis</a>
                </div>

                <div class="cinema-card mb-4 animate-fade-in-up" style="animation-delay: 0.1s;">
                    <div class="cinema-card-header">Detalji kupca</div>
                    <div class="cinema-card-body">
                        <dl class="cinema-details-list">
                            <dt>ID</dt>
                            <dd>@Model.Customer.Id</dd>

                            <dt>Ime</dt>
                            <dd>@Model.Customer.FirstName</dd>

                            <dt>Prezime</dt>
                            <dd>@Model.Customer.LastName</dd>

                            <dt>Grad</dt>
                            <dd>@Model.Customer.City</dd>

                            <dt>Adresa</dt>
                            <dd>@Model.Customer.Street @Model.Customer.HouseNumber, @Model.Customer.PostalCode</dd>

                            <dt>E-pošta</dt>
                            <dd>@Model.Customer.Email</dd>

                            <dt>Telefon</dt>
                            <dd>@Model.Customer.Phone</dd>

                            <dt>Datum registracije</dt>
                            <dd>@Model.Customer.RegisteredAt.ToString("dd.MM.yyyy")</dd>

                            <dt>Član programa vjernosti</dt>
                            <dd>@(Model.Customer.IsLoyaltyMember ? "Da" : "Ne")</dd>

                            <dt>Bodovi programa vjernosti</dt>
                            <dd>@Model.Customer.LoyaltyPoints</dd>
                        </dl>
                    </div>
                </div>

                <div class="cinema-card animate-fade-in-up" style="animation-delay: 0.2s;">
                    <div class="cinema-card-header">Ulaznice kupca</div>
                    <div class="cinema-table-wrapper cinema-table-wrapper--no-scroll">
                        @if (Model.Tickets.Any())
                        {
                            <table class="table customer-details-ticket-table">
                                <thead>
                                    <tr>
                                        <th>Broj ulaznice</th>
                                        <th>Film</th>
                                        <th>Kino</th>
                                        <th>Dvorana</th>
                                        <th>Kupnja</th>
                                        <th>Cijena (EUR)</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ticket in Model.Tickets)
                                    {
                                        <tr>
                                            <td>@ticket.TicketNumber</td>
                                            <td>@(ticket.Screening?.Movie?.Title ?? "-")</td>
                                            <td>@(ticket.Screening?.Hall?.Cinema?.Name ?? "-")</td>
                                            <td>@(ticket.Screening?.Hall?.Name ?? "-")</td>
                                            <td>@ticket.PurchasedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td>@ticket.Price.ToString("0.00")</td>
                                            <td>@ticket.Status</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="cinema-card-body">
                                <p class="text-muted mb-0">Kupac trenutno nema nijednu ulaznicu.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
