@model Vjezba.Model.Models.Entities.Seat

@{
    ViewData["Title"] = "Detalji sjedala";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    Sjedalo @Model.RowLabel@Model.SeatNumber</h1>
                    <a asp-action="Index" class="cinema-btn-secondary">Natrag na popis</a>
                </div>

                <div class="cinema-card animate-fade-in-up" style="animation-delay: 0.1s;">
                    <div class="cinema-card-header">Detalji sjedala</div>
                    <div class="cinema-card-body">
                        <dl class="cinema-details-list">
                            <dt>ID</dt>
                            <dd>@Model.Id</dd>

                            <dt>Kino</dt>
                            <dd>@(Model.Hall?.Cinema?.Name ?? "-")</dd>

                            <dt>Dvorana</dt>
                            <dd>@(Model.Hall?.Name ?? "-")</dd>

                            <dt>Red</dt>
                            <dd>@Model.RowLabel</dd>

                            <dt>Broj sjedala</dt>
                            <dd>@Model.SeatNumber</dd>

                            <dt>Tip sjedala</dt>
                            <dd>@Model.SeatType</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
