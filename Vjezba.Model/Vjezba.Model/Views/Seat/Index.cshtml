@model List<Vjezba.Model.Models.Entities.Seat>

@{
    ViewData["Title"] = "Sjedala";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Popis sjedala</h1>
        <span class="badge bg-primary">Ukupno: @Model.Count</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Kino</th>
                        <th>Dvorana</th>
                        <th>Red</th>
                        <th>Broj sjedala</th>
                        <th>Oznaka</th>
                        <th>Tip sjedala</th>
                        <th class="text-end">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var seat in Model)
                    {
                        <tr>
                            <td>@seat.Id</td>
                            <td>@(seat.Hall?.Cinema?.Name ?? "-")</td>
                            <td>@(seat.Hall?.Name ?? "-")</td>
                            <td>@seat.RowLabel</td>
                            <td>@seat.SeatNumber</td>
                            <td>@seat.RowLabel@seat.SeatNumber</td>
                            <td>@seat.SeatType</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@seat.Id" class="btn btn-sm btn-outline-primary">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
