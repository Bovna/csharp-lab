@model List<Vjezba.Model.Models.Entities.Seat>

@{
    ViewData["Title"] = "Sjedala";
}

<div class="container py-4 animate-fade-in-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">Popis
            sjedala</h1>
            <span class="cinema-badge">Ukupno: @Model.Count</span>
        </div>

        <div class="cinema-card">
            <div class="cinema-table-wrapper cinema-table-wrapper--no-scroll">
                <table class="table entity-index-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Kino</th>
                            <th>Dvorana</th>
                            <th>Oznaka sjedala</th>
                            <th>Tip sjedala</th>
                            <th>Dodatno</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var seat in Model)
                        {
                            <tr>
                                <td class="text-muted">@seat.Id</td>
                                <td>@(seat.Hall?.Cinema?.Name ?? "-")</td>
                                <td>@(seat.Hall?.Name ?? "-")</td>
                                <td>@seat.RowLabel@seat.SeatNumber</td>
                                <td>@seat.SeatType</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@seat.Id" class="cinema-btn-outline">Detalji</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
