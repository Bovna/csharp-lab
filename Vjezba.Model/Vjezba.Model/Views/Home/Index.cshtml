@{
    ViewData["Title"] = "Početna";
}

<div class="hero-section animate-fade-in-up">
    <h1 class="hero-title">Filmsko iskustvo na novoj razini</h1>
    <p class="hero-subtitle">Vaše omiljene projekcije, vrhunska udobnost i brza kupnja karata na jednom mjestu.</p>
    <div class="hero-actions">
        <a href="~/TicketBuilder" class="btn btn-primary btn-lg buy-ticket-btn">Kupi ulaznicu</a>
        <a href="~/Movie" class="btn btn-lg">Svi filmovi</a>
    </div>
</div>

<div class="benefits-section animate-fade-in-up" style="animation-delay: 0.1s;">
    <div class="benefit-card">
        <div class="benefit-icon">01</div>
        <h3>Najnoviji hitovi</h3>
        <p>Gledajte premijere i najpopularnije naslove na velikom platnu u najvišoj kvaliteti slike i zvuka.</p>
    </div>
    <div class="benefit-card">
        <div class="benefit-icon">02</div>
        <h3>Brza kupnja</h3>
        <p>Osigurajte svoje ulaznice i omiljena sjedala u samo nekoliko jednostavnih koraka iz udobnosti svog doma.</p>
    </div>
    <div class="benefit-card">
        <div class="benefit-icon">03</div>
        <h3>Premium sjedala</h3>
        <p>Odaberite savršenu poziciju u dvorani za maksimalnu udobnost tijekom cijele projekcije.</p>
    </div>
</div>
