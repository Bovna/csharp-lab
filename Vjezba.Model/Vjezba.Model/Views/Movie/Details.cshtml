@model Vjezba.Model.Models.Entities.Movie

@{
    ViewData["Title"] = "Detalji filma";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    @Model.Title</h1>
                    <a asp-action="Index" class="cinema-btn-secondary">Natrag na popis</a>
                </div>

                <div class="cinema-card animate-fade-in-up" style="animation-delay: 0.1s;">
                    <div class="cinema-card-header">Detalji filma</div>
                    <div class="cinema-card-body">
                        <dl class="cinema-details-list">
                            <dt>ID</dt>
                            <dd>@Model.Id</dd>

                            <dt>Naslov</dt>
                            <dd>@Model.Title</dd>

                            <dt>Opis</dt>
                            <dd>@Model.Description</dd>

                            <dt>Žanr</dt>
                            <dd>@Model.Genre</dd>

                            <dt>Trajanje</dt>
                            <dd>@Model.DurationMinutes min</dd>

                            <dt>Jezik</dt>
                            <dd>@Model.Language</dd>

                            <dt>Dobna oznaka</dt>
                            <dd>@Model.AgeRating</dd>

                            <dt>Datum izlaska</dt>
                            <dd>@Model.ReleaseDate.ToString("dd.MM.yyyy")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
