@model List<Vjezba.Model.Models.Entities.Movie>

@{
    ViewData["Title"] = "Filmovi";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Popis filmova</h1>
        <span class="badge bg-primary">Ukupno: @Model.Count</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Naslov</th>
                        <th>Opis</th>
                        <th>Zanr</th>
                        <th>Trajanje (min)</th>
                        <th>Jezik</th>
                        <th>Dobna oznaka</th>
                        <th>Datum izlaska</th>
                        <th class="text-end">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movie in Model)
                    {
                        <tr>
                            <td>@movie.Id</td>
                            <td>@movie.Title</td>
                            <td>@movie.Description</td>
                            <td>@movie.Genre</td>
                            <td>@movie.DurationMinutes</td>
                            <td>@movie.Language</td>
                            <td>@movie.AgeRating</td>
                            <td>@movie.ReleaseDate.ToString("dd.MM.yyyy")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-primary">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
