@model Vjezba.Model.Models.Entities.Ticket

@{
    ViewData["Title"] = "Detalji ulaznice";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    Ulaznica @Model.TicketNumber</h1>
                    <a asp-action="Index" class="cinema-btn-secondary">Natrag na popis</a>
                </div>

                <div class="cinema-card animate-fade-in-up" style="animation-delay: 0.1s;">
                    <div class="cinema-card-header">Detalji ulaznice</div>
                    <div class="cinema-card-body">
                        <dl class="cinema-details-list">
                            <dt>ID</dt>
                            <dd>@Model.Id</dd>

                            <dt>Broj ulaznice</dt>
                            <dd>@Model.TicketNumber</dd>

                            <dt>Kupac</dt>
                            <dd>@(Model.Customer is null ? "-" : $"{Model.Customer.FirstName} {Model.Customer.LastName}")
                            </dd>

                            <dt>Film</dt>
                            <dd>@(Model.Screening?.Movie?.Title ?? "-")</dd>

                            <dt>Kino</dt>
                            <dd>@(Model.Screening?.Hall?.Cinema?.Name ?? "-")</dd>

                            <dt>Dvorana</dt>
                            <dd>@(Model.Screening?.Hall?.Name ?? "-")</dd>

                            <dt>Sjedalo</dt>
                            <dd>@(Model.Seat is null ? "-" : $"{Model.Seat.RowLabel}{Model.Seat.SeatNumber}")</dd>

                            <dt>Kupnja</dt>
                            <dd>@Model.PurchasedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                            <dt>Cijena</dt>
                            <dd>@Model.Price.ToString("0.00") EUR</dd>

                            <dt>Status</dt>
                            <dd>
                                @(Model.Status switch
                                {
                                    Vjezba.Model.Models.Entities.TicketStatus.Active => "Aktivna",
                                    Vjezba.Model.Models.Entities.TicketStatus.Cancelled => "Otkazana",
                                    Vjezba.Model.Models.Entities.TicketStatus.Used => "Iskoristena",
                                    _ => Model.Status.ToString()
                                })
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
