@model List<Vjezba.Model.Models.Entities.Ticket>

@{
    ViewData["Title"] = "Ulaznice";
}

<div class="container py-4 animate-fade-in-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">Popis
            ulaznica</h1>
            <span class="cinema-badge">Ukupno: @Model.Count</span>
        </div>

        <div class="cinema-card">
            <div class="cinema-table-wrapper cinema-table-wrapper--no-scroll">
                <table class="table entity-index-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Broj ulaznice</th>
                            <th>Kupac</th>
                            <th>Film</th>
                            <th>Kino</th>
                            <th>Dvorana</th>
                            <th>Sjedalo</th>
                            <th>Vrijeme projekcije</th>
                            <th>Cijena (EUR)</th>
                            <th>Status</th>
                            <th>Dodatno</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="text-muted">@ticket.Id</td>
                                <td>@ticket.TicketNumber</td>
                                <td>@(ticket.Customer is null ? "-" : $"{ticket.Customer.FirstName} {ticket.Customer.LastName}")
                                </td>
                                <td>@(ticket.Screening?.Movie?.Title ?? "-")</td>
                                <td>@(ticket.Screening?.Hall?.Cinema?.Name ?? "-")</td>
                                <td>@(ticket.Screening?.Hall?.Name ?? "-")</td>
                                <td>@(ticket.Seat is null ? "-" : $"{ticket.Seat.RowLabel}{ticket.Seat.SeatNumber}")</td>
                                <td>@(ticket.Screening is null ? "-" : ticket.Screening.StartTime.ToString("dd.MM.yyyy HH:mm"))
                                </td>
                                <td>@ticket.Price.ToString("0.00")</td>
                                <td>
                                    @(ticket.Status switch
                                    {
                                        Vjezba.Model.Models.Entities.TicketStatus.Active => "Aktivna",
                                        Vjezba.Model.Models.Entities.TicketStatus.Cancelled => "Otkazana",
                                        Vjezba.Model.Models.Entities.TicketStatus.Used => "Iskoristena",
                                        _ => ticket.Status.ToString()
                                    })
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@ticket.Id" class="cinema-btn-outline">Detalji</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
