@model List<Vjezba.Model.Models.Entities.Ticket>

@{
    ViewData["Title"] = "Ulaznice";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Popis ulaznica</h1>
        <span class="badge bg-primary">Ukupno: @Model.Count</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Broj ulaznice</th>
                        <th>Kupac</th>
                        <th>Film</th>
                        <th>Kino</th>
                        <th>Dvorana</th>
                        <th>Sjedalo</th>
                        <th>Kupnja</th>
                        <th>Cijena (EUR)</th>
                        <th>Status</th>
                        <th class="text-end">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td>@ticket.Id</td>
                            <td>@ticket.TicketNumber</td>
                            <td>@(ticket.Customer is null ? "-" : $"{ticket.Customer.FirstName} {ticket.Customer.LastName}")
                            </td>
                            <td>@(ticket.Screening?.Movie?.Title ?? "-")</td>
                            <td>@(ticket.Screening?.Hall?.Cinema?.Name ?? "-")</td>
                            <td>@(ticket.Screening?.Hall?.Name ?? "-")</td>
                            <td>@(ticket.Seat is null ? "-" : $"{ticket.Seat.RowLabel}{ticket.Seat.SeatNumber}")</td>
                            <td>@ticket.PurchasedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@ticket.Price.ToString("0.00")</td>
                            <td>
                                @(ticket.Status switch
                                {
                                    Vjezba.Model.Models.Entities.TicketStatus.Active => "Aktivna",
                                    Vjezba.Model.Models.Entities.TicketStatus.Cancelled => "Otkazana",
                                    Vjezba.Model.Models.Entities.TicketStatus.Used => "Iskoristena",
                                    _ => ticket.Status.ToString()
                                })
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-primary">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
