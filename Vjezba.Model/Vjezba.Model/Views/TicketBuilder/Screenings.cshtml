@model Vjezba.Model.Models.ViewModels.TicketBuilderScreeningListViewModel
@{
    ViewData["Title"] = "Ticket Builder - Projekcije";
}

<div class="tb-page">
    <div class="tb-header">
        <h1>@Model.MovieTitle</h1>
        <p>Korak 3/4: odaberi projekciju</p>
    </div>

    <div class="tb-step-line">
        <a class="tb-step" asp-controller="TicketBuilder" asp-action="Index">1 Kino</a>
        <a class="tb-step" asp-controller="TicketBuilder" asp-action="Movies" asp-route-cinemaId="@Model.CinemaId">2
            Film</a>
            <span class="tb-step active">3 Projekcija</span>
            <span class="tb-step">4 Sjedalo</span>
        </div>

        @if (!Model.Screenings.Any())
        {
            <p>Nema dostupnih projekcija za ovaj film u odabranom kinu.</p>
        }
        else
        {
            <div class="tb-list">
                @foreach (var screening in Model.Screenings)
                {
                    <a class="tb-list-item" asp-controller="TicketBuilder" asp-action="Seats" asp-route-cinemaId="@Model.CinemaId"
                           asp-route-movieId="@Model.MovieId" asp-route-screeningId="@screening.Id">
                        <strong>@screening.StartTime.ToString("dd.MM.yyyy HH:mm") - @screening.EndTime.ToString("HH:mm")</strong>
                        <small>@screening.HallName @(screening.Is3D ? "| 3D" : "")</small>
                    </a>
                }
            </div>
        }
    </div>
