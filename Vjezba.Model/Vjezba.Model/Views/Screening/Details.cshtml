@model Vjezba.Model.Models.Entities.Screening

@{
    ViewData["Title"] = "Detalji projekcije";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h3 mb-0">Projekcija #@Model.Id</h1>
                <a asp-action="Index" class="btn btn-outline-secondary">Natrag na popis</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">Film</dt>
                        <dd class="col-sm-8">@(Model.Movie?.Title ?? "-")</dd>

                        <dt class="col-sm-4">Kino</dt>
                        <dd class="col-sm-8">@(Model.Hall?.Cinema?.Name ?? "-")</dd>

                        <dt class="col-sm-4">Dvorana</dt>
                        <dd class="col-sm-8">@(Model.Hall?.Name ?? "-")</dd>

                        <dt class="col-sm-4">Pocetak</dt>
                        <dd class="col-sm-8">@Model.StartTime.ToString("dd.MM.yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Zavrsetak</dt>
                        <dd class="col-sm-8">@Model.EndTime.ToString("dd.MM.yyyy HH:mm")</dd>

                        <dt class="col-sm-4">3D projekcija</dt>
                        <dd class="col-sm-8">@(Model.Is3D ? "Da" : "Ne")</dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header">Ulaznice za projekciju</div>
                <div class="card-body p-0">
                    @if (Model.Tickets.Count == 0)
                    {
                        <div class="p-3 text-muted">Nema ulaznica za ovu projekciju.</div>
                    }
                    else
                    {
                        <table class="table table-striped mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Broj ulaznice</th>
                                    <th>Kupac</th>
                                    <th>Sjedalo</th>
                                    <th>Kupnja</th>
                                    <th>Cijena (EUR)</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ticket in Model.Tickets)
                                {
                                    <tr>
                                        <td>@ticket.TicketNumber</td>
                                        <td>@(ticket.Customer is null ? "-" : $"{ticket.Customer.FirstName} {ticket.Customer.LastName}")</td>
                                        <td>@(ticket.Seat is null ? "-" : $"{ticket.Seat.RowLabel}{ticket.Seat.SeatNumber}")</td>
                                        <td>@ticket.PurchasedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@ticket.Price.ToString("0.00")</td>
                                        <td>
                                            @(ticket.Status switch
                                            {
                                                Vjezba.Model.Models.Entities.TicketStatus.Active => "Aktivna",
                                                Vjezba.Model.Models.Entities.TicketStatus.Cancelled => "Otkazana",
                                                Vjezba.Model.Models.Entities.TicketStatus.Used => "Iskoristena",
                                                _ => ticket.Status.ToString()
                                            })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
