@model Vjezba.Model.Models.ViewModels.ScreeningDetailsViewModel

@{
    ViewData["Title"] = "Detalji projekcije";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    Projekcija #@Model.Screening.Id</h1>
                    <a asp-action="Index" class="cinema-btn-secondary">Natrag na popis</a>
                </div>

                <div class="cinema-card mb-4 animate-fade-in-up" style="animation-delay: 0.1s;">
                    <div class="cinema-card-header">Detalji projekcije</div>
                    <div class="cinema-card-body">
                        <dl class="cinema-details-list">
                            <dt>ID</dt>
                            <dd>@Model.Screening.Id</dd>

                            <dt>Film</dt>
                            <dd>@(Model.Screening.Movie?.Title ?? "-")</dd>

                            <dt>Kino</dt>
                            <dd>@(Model.Screening.Hall?.Cinema?.Name ?? "-")</dd>

                            <dt>Dvorana</dt>
                            <dd>@(Model.Screening.Hall?.Name ?? "-")</dd>

                            <dt>Početak</dt>
                            <dd>@Model.Screening.StartTime.ToString("dd.MM.yyyy HH:mm")</dd>

                            <dt>Završetak</dt>
                            <dd>@Model.Screening.EndTime.ToString("dd.MM.yyyy HH:mm")</dd>

                            <dt>3D projekcija</dt>
                            <dd>
                                @if (Model.Screening.Is3D)
                                {
                                    <span class="cinema-status-yes">Da</span>
                                }
                                else
                                {
                                    <span style="color: var(--color-text-muted);">Ne</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="cinema-card animate-fade-in-up" style="animation-delay: 0.2s;">
                    <div class="cinema-card-header">Ulaznice za projekciju</div>
                    <div class="cinema-table-wrapper">
                        @if (Model.Tickets.Any())
                        {
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Broj ulaznice</th>
                                        <th>Kupac</th>
                                        <th>Sjedalo</th>
                                        <th>Kupnja</th>
                                        <th>Cijena (EUR)</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ticket in Model.Tickets)
                                    {
                                        <tr>
                                            <td>@ticket.TicketNumber</td>
                                            <td>@(ticket.Customer is null ? "-" : $"{ticket.Customer.FirstName}                             {ticket.Customer.LastName}")</td>
                                            <td>@(ticket.Seat is null ? "-" : $"{ticket.Seat.RowLabel}{ticket.Seat.SeatNumber}")
                                            </td>
                                            <td>@ticket.PurchasedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td>@ticket.Price.ToString("0.00")</td>
                                            <td>@ticket.Status</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="cinema-card-body">
                                <p class="text-muted mb-0">Za ovu projekciju trenutno nema ulaznica.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
