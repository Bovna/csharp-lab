@model List<Vjezba.Model.Models.Entities.Screening>

@{
    ViewData["Title"] = "Projekcije";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3 mb-0">Popis projekcija</h1>
        <span class="badge bg-primary">Ukupno: @Model.Count</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Film</th>
                        <th>Kino</th>
                        <th>Dvorana</th>
                        <th>Pocetak</th>
                        <th>Zavrsetak</th>
                        <th>3D projekcija</th>
                        <th class="text-end">Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var screening in Model)
                    {
                        <tr>
                            <td>@screening.Id</td>
                            <td>@(screening.Movie?.Title ?? "-")</td>
                            <td>@(screening.Hall?.Cinema?.Name ?? "-")</td>
                            <td>@(screening.Hall?.Name ?? "-")</td>
                            <td>@screening.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@screening.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(screening.Is3D ? "Da" : "Ne")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@screening.Id" class="btn btn-sm btn-outline-primary">Detalji</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
