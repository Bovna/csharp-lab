@model List<Vjezba.Model.Models.Entities.Screening>

@{
    ViewData["Title"] = "Projekcije";
}

<div class="container py-4 animate-fade-in-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">Popis
            projekcija</h1>
            <span class="cinema-badge">Ukupno: @Model.Count</span>
        </div>

        <div class="cinema-card">
            <div class="cinema-table-wrapper cinema-table-wrapper--no-scroll">
                <table class="table entity-index-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Film</th>
                            <th>Kino</th>
                            <th>Dvorana</th>
                            <th>Početak</th>
                            <th>Završetak</th>
                            <th>3D projekcija</th>
                            <th>Dodatno</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var screening in Model)
                        {
                            <tr>
                                <td class="text-muted">@screening.Id</td>
                                <td>@(screening.Movie?.Title ?? "-")</td>
                                <td>@(screening.Hall?.Cinema?.Name ?? "-")</td>
                                <td>@(screening.Hall?.Name ?? "-")</td>
                                <td>@screening.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@screening.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>
                                    @if (screening.Is3D)
                                    {
                                        <span class="cinema-status-yes">Da</span>
                                    }
                                    else
                                    {
                                        <span class="cinema-status-no">Ne</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@screening.Id" class="cinema-btn-outline">Detalji</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
