@model List<Vjezba.Model.Models.Entities.Hall>

@{
    ViewData["Title"] = "Dvorane";
}

<div class="container py-4 animate-fade-in-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">Popis
            dvorana</h1>
            <span class="cinema-badge">Ukupno: @Model.Count</span>
        </div>

        <div class="cinema-card">
            <div class="cinema-table-wrapper cinema-table-wrapper--no-scroll">
                <table class="table entity-index-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Naziv</th>
                            <th>Kino</th>
                            <th>Kapacitet</th>
                            <th>3D podrška</th>
                            <th>Dodatno</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var hall in Model)
                        {
                            <tr>
                                <td class="text-muted">@hall.Id</td>
                                <td>@hall.Name</td>
                                <td>@(hall.Cinema?.Name ?? "-")</td>
                                <td>@hall.Capacity</td>
                                <td>
                                    @if (hall.Supports3D)
                                    {
                                        <span class="cinema-status-yes">Da</span>
                                    }
                                    else
                                    {
                                        <span class="cinema-status-no">Ne</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@hall.Id" class="cinema-btn-outline">Detalji</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
