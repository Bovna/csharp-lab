@model Vjezba.Model.Models.Entities.Cinema

@{
    ViewData["Title"] = "Detalji kina";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h3 mb-0">@Model.Name</h1>
                <a asp-action="Index" class="btn btn-outline-secondary">Natrag na popis</a>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">Naziv</dt>
                        <dd class="col-sm-8">@Model.Name</dd>

                        <dt class="col-sm-4">Grad</dt>
                        <dd class="col-sm-8">@Model.City</dd>

                        <dt class="col-sm-4">Adresa</dt>
                        <dd class="col-sm-8">@Model.Street @Model.HouseNumber</dd>

                        <dt class="col-sm-4">Postanski broj</dt>
                        <dd class="col-sm-8">@Model.PostalCode</dd>

                        <dt class="col-sm-4">Drzava</dt>
                        <dd class="col-sm-8">Hrvatska</dd>

                        <dt class="col-sm-4">E-posta</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Telefon</dt>
                        <dd class="col-sm-8">@Model.Phone</dd>

                        <dt class="col-sm-4">Broj dvorana</dt>
                        <dd class="col-sm-8">@Model.Halls.Count</dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header">Dvorane</div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Naziv</th>
                                <th>Kapacitet</th>
                                <th>3D</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var hall in Model.Halls)
                            {
                                <tr>
                                    <td>@hall.Id</td>
                                    <td>@hall.Name</td>
                                    <td>@hall.Capacity</td>
                                    <td>@(hall.Supports3D ? "Da" : "Ne")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
