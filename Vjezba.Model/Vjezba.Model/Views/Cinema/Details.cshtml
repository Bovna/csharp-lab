@model Vjezba.Model.Models.Entities.Cinema

@{
    ViewData["Title"] = "Detalji kina";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    @Model.Name</h1>
                    <a asp-action="Index" class="cinema-btn-secondary">Natrag na popis</a>
                </div>

                <div class="cinema-card mb-4 animate-fade-in-up" style="animation-delay: 0.1s;">
                    <div class="cinema-card-header">Detalji Kina</div>
                    <div class="cinema-card-body">
                        <dl class="cinema-details-list">
                            <dt>ID</dt>
                            <dd>@Model.Id</dd>

                            <dt>Naziv</dt>
                            <dd>@Model.Name</dd>

                            <dt>Grad</dt>
                            <dd>@Model.City</dd>

                            <dt>Adresa</dt>
                            <dd>@Model.Street @Model.HouseNumber</dd>

                            <dt>Poštanski broj</dt>
                            <dd>@Model.PostalCode</dd>

                            <dt>Država</dt>
                            <dd>Hrvatska</dd>

                            <dt>E-pošta</dt>
                            <dd>@Model.Email</dd>

                            <dt>Telefon</dt>
                            <dd>@Model.Phone</dd>

                            <dt>Broj dvorana</dt>
                            <dd>@Model.Halls.Count</dd>
                        </dl>
                    </div>
                </div>

                <div class="cinema-card animate-fade-in-up" style="animation-delay: 0.2s;">
                    <div class="cinema-card-header">Dvorane</div>
                    <div class="cinema-table-wrapper">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Naziv</th>
                                    <th>Kapacitet</th>
                                    <th>3D Podrška</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hall in Model.Halls)
                                {
                                    <tr>
                                        <td class="text-muted">@hall.Id</td>
                                        <td style="font-weight: 500; color: #fff;">@hall.Name</td>
                                        <td>@hall.Capacity mjesta</td>
                                        <td>
                                            @if (hall.Supports3D)
                                            {
                                                <span class="cinema-status-yes">Da</span>
                                            }
                                            else
                                            {
                                                <span style="color: var(--color-text-muted);">Ne</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
