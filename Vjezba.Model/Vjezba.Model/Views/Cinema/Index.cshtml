@model List<Vjezba.Model.Models.Entities.Cinema>

@{
    ViewData["Title"] = "Kina";
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h3 mb-0">Popis kina</h1>
                <span class="badge bg-primary">Ukupno: @Model.Count</span>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Naziv</th>
                                <th>Grad</th>
                                <th>Adresa</th>
                                <th>Postanski broj</th>
                                <th>Drzava</th>
                                <th>Broj dvorana</th>
                                <th>E-posta</th>
                                <th>Telefon</th>
                                <th class="text-end">Akcije</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cinema in Model)
                            {
                                <tr>
                                    <td>@cinema.Id</td>
                                    <td>@cinema.Name</td>
                                    <td>@cinema.City</td>
                                    <td>@cinema.Street @cinema.HouseNumber</td>
                                    <td>@cinema.PostalCode</td>
                                    <td>Hrvatska</td>
                                    <td>@cinema.Halls.Count</td>
                                    <td>@cinema.Email</td>
                                    <td>@cinema.Phone</td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@cinema.Id" class="btn btn-sm btn-outline-primary">
                                            Detalji
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
