@model List<Vjezba.Model.Models.Entities.Cinema>

@{
    ViewData["Title"] = "Kina";
}

<div class="container py-4 animate-fade-in-up">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0" style="color: var(--color-accent); letter-spacing: 1px; text-transform: uppercase;">
                    Popis kina</h1>
                    <span class="cinema-badge">Ukupno: @Model.Count</span>
                </div>

                <div class="cinema-card">
                    <div class="cinema-table-wrapper cinema-table-wrapper--no-scroll">
                        <table class="table entity-index-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Naziv</th>
                                    <th>Grad</th>
                                    <th>Adresa</th>
                                    <th>Poštanski broj</th>
                                    <th>Država</th>
                                    <th>Broj dvorana</th>
                                    <th>E-pošta</th>
                                    <th>Telefon</th>
                                    <th>Dodatno</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cinema in Model)
                                {
                                    <tr>
                                        <td class="text-muted" title="@cinema.Id">@cinema.Id</td>
                                        <td style="font-weight: 500; color: #fff;" title="@cinema.Name">@cinema.Name</td>
                                        <td title="@cinema.City">@cinema.City</td>
                                        <td title="@cinema.Street @cinema.HouseNumber">@cinema.Street @cinema.HouseNumber
                                        </td>
                                        <td title="@cinema.PostalCode">@cinema.PostalCode</td>
                                        <td>Hrvatska</td>
                                        <td title="@cinema.Halls.Count">@cinema.Halls.Count</td>
                                        <td title="@cinema.Email">@cinema.Email</td>
                                        <td title="@cinema.Phone">@cinema.Phone</td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@cinema.Id" class="cinema-btn-outline">
                                                Detalji
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
