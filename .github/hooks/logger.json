{
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -File \".github/hooks/log-agent-input.ps1\" -EventType \"UserPromptSubmit\" -LogFile \".github/logs/agent_log.txt\""
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -File \".github/hooks/log-agent-input.ps1\" -EventType \"PreToolUse\" -LogFile \".github/logs/agent_log.txt\""
      }
    ]
  }
}
